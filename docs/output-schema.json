{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aigenguard.dev/schemas/output-schema.json",
  "title": "AigenGuard Output",
  "type": "object",
  "required": [
    "schema_version",
    "repository",
    "generated_by",
    "providers",
    "models",
    "frameworks",
    "mcp_servers",
    "prompts",
    "capabilities",
    "dependencies",
    "reachable_capabilities",
    "capability_graph",
    "policy_findings",
    "repository_risk",
    "secret_references",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "generated_by": {
      "type": "string"
    },
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/model_finding"
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mcp_server_finding"
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/prompt_finding"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency_finding"
      }
    },
    "reachable_capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reachable_capability"
      }
    },
    "capability_graph": {
      "$ref": "#/$defs/capability_graph"
    },
    "policy_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy_finding"
      }
    },
    "repository_risk": {
      "$ref": "#/$defs/repository_risk"
    },
    "secret_references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/named_finding"
      }
    },
    "secret_leak_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/secret_leak_finding"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "diff": {
      "$ref": "#/$defs/diff"
    },
    "policy_review": {
      "$ref": "#/$defs/policy_review"
    }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "policy_status": {
      "type": "string",
      "enum": [
        "undocumented",
        "documented_by_repository_policy",
        "policy_warning",
        "policy_violation",
        "not_applicable"
      ]
    },
    "named_finding": {
      "type": "object",
      "required": [
        "name",
        "path",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "policy_status": {
          "$ref": "#/$defs/policy_status"
        }
      }
    },
    "mcp_server_finding": {
      "type": "object",
      "required": [
        "name",
        "path",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "kind": {
          "type": "string",
          "enum": [
            "config_file",
            "server"
          ]
        },
        "parse_status": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transport": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "risk_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "filesystem_access",
              "shell_process_execution",
              "browser_network_access",
              "database_access",
              "cloud_access",
              "secrets_env_access",
              "unknown_custom_server"
            ]
          }
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_status": {
          "$ref": "#/$defs/policy_status"
        }
      }
    },
    "model_finding": {
      "type": "object",
      "required": [
        "type",
        "name",
        "source_file",
        "confidence",
        "evidence"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "prompt_finding": {
      "type": "object",
      "required": [
        "path",
        "type",
        "confidence"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "dependency_finding": {
      "type": "object",
      "required": [
        "name",
        "category",
        "path",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "ai_framework",
            "mcp",
            "provider_sdk",
            "sandbox_runtime"
          ]
        },
        "path": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "reachable_capability": {
      "type": "object",
      "required": [
        "capability",
        "reachable_from",
        "source_file",
        "risk",
        "confidence"
      ],
      "properties": {
        "capability": {
          "type": "string"
        },
        "reachable_from": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "risk": {
          "type": "string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "confidence_score": {
          "type": "integer"
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "prompt_input",
              "tool_invocation",
              "shell_execution",
              "network_execution"
            ]
          }
        },
        "mcp_server": {
          "type": "string"
        },
        "risk_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mitigations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_status": {
          "$ref": "#/$defs/policy_status"
        }
      }
    },
    "repository_risk": {
      "type": "object",
      "required": [
        "score",
        "severity",
        "rationale"
      ],
      "properties": {
        "score": {
          "type": "integer"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "rationale": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "severity",
        "reason"
      ],
      "properties": {
        "severity": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "policy_finding": {
      "type": "object",
      "required": [
        "severity",
        "message",
        "source_file"
      ],
      "properties": {
        "severity": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "policy_id": {
          "type": "string"
        },
        "policy_status": {
          "$ref": "#/$defs/policy_status"
        }
      }
    },
    "secret_leak_finding": {
      "type": "object",
      "required": [
        "provider",
        "category",
        "severity",
        "confidence",
        "path",
        "line",
        "redacted_evidence",
        "suggested_action"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "path": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "redacted_evidence": {
          "type": "string"
        },
        "suggested_action": {
          "type": "string"
        }
      }
    },
    "policy_review": {
      "type": "object",
      "required": [
        "passed",
        "mode",
        "violations",
        "warnings"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "enforced"
          ]
        },
        "policy_file": {
          "type": "string"
        },
        "violations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policy_review_item"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/policy_review_item"
          }
        }
      }
    },
    "policy_review_item": {
      "type": "object",
      "required": [
        "rule",
        "severity",
        "message"
      ],
      "properties": {
        "rule": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "message": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "suggested_remediation": {
          "type": "string"
        },
        "policy_status": {
          "$ref": "#/$defs/policy_status"
        }
      }
    },
    "capability_graph": {
      "type": "object",
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_edge"
          }
        }
      }
    },
    "graph_node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "model",
            "framework",
            "capability",
            "provider",
            "prompt",
            "mcp_server",
            "reachable_capability",
            "mcp_risk"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "graph_edge": {
      "type": "object",
      "required": [
        "source",
        "target",
        "type"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "uses",
            "enables",
            "reaches",
            "exposes",
            "risk"
          ]
        }
      }
    },
    "diff": {
      "type": "object",
      "required": [
        "baseline_repository",
        "current_repository",
        "introduced",
        "resolved",
        "unchanged"
      ],
      "properties": {
        "baseline_repository": {
          "type": "string"
        },
        "current_repository": {
          "type": "string"
        },
        "introduced": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diff_finding"
          }
        },
        "resolved": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diff_finding"
          }
        },
        "unchanged": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diff_finding"
          }
        }
      }
    },
    "diff_finding": {
      "type": "object",
      "required": [
        "id",
        "category",
        "title",
        "source_file",
        "severity"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
